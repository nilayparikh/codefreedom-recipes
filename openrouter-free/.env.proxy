# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for OpenRouter free-tier
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe uses OpenRouter free-tier models as the sole provider.
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Instance identifier ───────────────────────────────────────────
SUFFIX_ID=0000

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — all pointing to OpenRouter free models
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/openrouter.yaml.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_BEST="OpenRouter/Nemotron-3-Ultra-550B-A55B"
LITELLM_MODEL_ALIAS_FABLE="OpenRouter/Nemotron-3-Ultra-550B-A55B"
LITELLM_MODEL_ALIAS_SONNET="OpenRouter/Nemotron-3-Ultra-550B-A55B"
LITELLM_MODEL_ALIAS_OPUS="OpenRouter/Nemotron-3-Ultra-550B-A55B"
LITELLM_MODEL_ALIAS_HAIKU="OpenRouter/FreeRouter"
LITELLM_MODEL_ALIAS_SONNET_1M="OpenRouter/Nemotron-3-Ultra-550B-A55B"
LITELLM_MODEL_ALIAS_OPUS_1M="OpenRouter/Nemotron-3-Ultra-550B-A55B"
LITELLM_MODEL_ALIAS_OPUSPLAN="OpenRouter/Nemotron-3-Ultra-550B-A55B"

# ═══════════════════════════════════════════════════════════════════════════════
# OpenRouter — Base URL
# ═══════════════════════════════════════════════════════════════════════════════
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
