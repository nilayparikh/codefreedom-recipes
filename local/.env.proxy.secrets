# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — Secrets for local inference
# ═══════════════════════════════════════════════════════════════════════════════
# Set your API keys here. NEVER commit this file to git.
#
# Most local inference servers (vLLM, llama.cpp, Ollama) don't require
# API key auth, but LiteLLM needs a non-empty placeholder.
# The defaults below work for typical local setups.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LiteLLM Proxy Master Key ───────────────────────────────────────────────
# Used to authenticate requests to the local proxy.
# This is the ANTHROPIC_AUTH_TOKEN value used in Claude Code profiles.
LITELLM_MASTER_KEY=sk-codefreedom-local

# ── Local Backend M (port 8000) — primary model ───────────────────────────
LOCAL_M_API_KEY=sk-dummy

# ── Local Backend S (port 8001) — fast / vision model ────────────────────
LOCAL_S_API_KEY=sk-dummy
