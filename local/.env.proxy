# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for local self-hosted inference
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe uses locally-hosted OpenAI-compatible inference servers.
# Two backends: M (port 8000, primary) and S (port 8001, fast/vision).
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — all pointing to local self-hosted models
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/local.yaml.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_ULTRA="DGX/Qwen3.6-27B"
LITELLM_MODEL_ALIAS_PRO="DGX/Qwen3.6-27B"
LITELLM_MODEL_ALIAS_FLASH="DGX/Qwen3.6-35B-A3B"
LITELLM_MODEL_ALIAS_AIR="DGX/Qwen3.6-35B-A3B"

# ═══════════════════════════════════════════════════════════════════════════════
# Local Backend — Base URLs
# ═══════════════════════════════════════════════════════════════════════════════
# Defaults assume inference servers on the Docker host.
# Override if your servers are on different hosts or ports.

LOCAL_M_BASE_URL=http://host.docker.internal:8000/v1
LOCAL_S_BASE_URL=http://host.docker.internal:8001/v1
