# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for NVIDIA AI Endpoints
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe uses NVIDIA AI Endpoints as the sole provider.
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Instance identifier ───────────────────────────────────────────
SUFFIX_ID=0000

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — all pointing to NVIDIA AI Endpoints
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/nvidia.yaml.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_ULTRA="NVIDIA/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_PRO="NVIDIA/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_FLASH="NVIDIA/DeepSeek-V4-Flash"
LITELLM_MODEL_ALIAS_AIR="NVIDIA/Step-3.7-Flash"

# ═══════════════════════════════════════════════════════════════════════════════
# NVIDIA — Base URL
# ═══════════════════════════════════════════════════════════════════════════════
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
