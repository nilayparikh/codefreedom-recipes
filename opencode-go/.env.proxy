# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for OpenCode GO + free-tier
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe uses OpenCode GO subscription + free-tier models (NPG).
# Includes both free OCZ models and paid OCG models under the same key.
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Instance identifier ───────────────────────────────────────────
SUFFIX_ID=0000

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — GO subscription + free models
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/opencode-npg.yaml.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_BEST="OCG/NPG/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_FABLE="OCG/NPG/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_SONNET="OCG/NPG/DeepSeek-V4-Flash"
LITELLM_MODEL_ALIAS_OPUS="OCG/NPG/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_HAIKU="OCZ/NPG/Big-Pickle"
LITELLM_MODEL_ALIAS_SONNET_1M="OCG/NPG/DeepSeek-V4-Flash"
LITELLM_MODEL_ALIAS_OPUS_1M="OCG/NPG/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_OPUSPLAN="OCG/NPG/DeepSeek-V4-Pro"

# ═══════════════════════════════════════════════════════════════════════════════
# OpenCode — Base URLs
# ═══════════════════════════════════════════════════════════════════════════════
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_ANTHROPIC_BASE_URL=https://opencode.ai/zen/go
