# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — Secrets for OpenCode GO + free-tier
# ═══════════════════════════════════════════════════════════════════════════════
# Set your API keys here. NEVER commit this file to git.
#
# The same NPG key unlocks both free (OCZ) and subscription (OCG) models.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LiteLLM Proxy Master Key ───────────────────────────────────────────────
# Used to authenticate requests to the local proxy.
# This is the ANTHROPIC_AUTH_TOKEN value used in Claude Code profiles.
LITELLM_MASTER_KEY=sk-codefreedom-local

# ── OpenCode Zen API Key (NPG) ─────────────────────────────────────────────
# Get free key at https://opencode.ai/zen
# Get GO subscription at https://opencode.ai/zen/go
OPENCODE_ZEN_API_KEY_NPG=
