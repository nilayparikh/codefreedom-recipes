# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for DeepSeek native API
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe uses the native DeepSeek API as the sole provider.
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Instance identifier ───────────────────────────────────────────
SUFFIX_ID=0000

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — all pointing to native DeepSeek models
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/deepseek.yaml.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_BEST="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_FABLE="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_SONNET="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_OPUS="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_HAIKU="DeepSeek/DeepSeek-V4-Flash"
LITELLM_MODEL_ALIAS_SONNET_1M="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_OPUS_1M="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_OPUSPLAN="DeepSeek/DeepSeek-V4-Pro"

# ═══════════════════════════════════════════════════════════════════════════════
# DeepSeek — Base URL
# ═══════════════════════════════════════════════════════════════════════════════
DEEPSEEK_BASE_URL=https://api.deepseek.com
