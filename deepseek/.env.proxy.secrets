# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — Secrets for DeepSeek native API
# ═══════════════════════════════════════════════════════════════════════════════
#
# ⚠️  RECOMMENDATION: Set secrets as machine environment variables instead of
#     keeping them in files. Export in your shell profile (~/.bashrc, ~/.zshrc):
#
#       export LITELLM_MASTER_KEY="sk-codefreedom-local"
#       export DEEPSEEK_API_KEY="your-deepseek-api-key"
#
#     This keeps sensitive values out of version control and config files.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LiteLLM Proxy Master Key ───────────────────────────────────────────────
# Used to authenticate requests to the local proxy.
# This is the ANTHROPIC_AUTH_TOKEN value used in Claude Code profiles.
# LITELLM_MASTER_KEY=sk-codefreedom-local   # 👈 set via: export LITELLM_MASTER_KEY="sk-codefreedom-local"

# ── DeepSeek API Key ───────────────────────────────────────────────────────
# Get your key at https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=                         # 👈 set via: export DEEPSEEK_API_KEY="your-key"
