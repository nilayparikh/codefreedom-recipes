# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — Secrets for DeepSeek native API
# ═══════════════════════════════════════════════════════════════════════════════
# Set your API keys here. NEVER commit this file to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LiteLLM Proxy Master Key ───────────────────────────────────────────────
# Used to authenticate requests to the local proxy.
# This is the ANTHROPIC_AUTH_TOKEN value used in Claude Code profiles.
LITELLM_MASTER_KEY=sk-codefreedom-local

# ── DeepSeek API Key ───────────────────────────────────────────────────────
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
