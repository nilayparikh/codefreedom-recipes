# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for free-tier models
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe combines free-tier models from NVIDIA, OpenRouter, and OpenCode Zen.
# No API keys required — all models are free tier.
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Instance identifier ───────────────────────────────────────────
SUFFIX_ID=0000

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — free-tier models across providers
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_BEST="OCZ/MNP/Nemotron-3-Ultra-FREE"
LITELLM_MODEL_ALIAS_FABLE="OCZ/MNP/Nemotron-3-Ultra-FREE"
LITELLM_MODEL_ALIAS_SONNET="NVIDIA/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_OPUS="OCZ/MNP/Nemotron-3-Ultra-FREE"
LITELLM_MODEL_ALIAS_HAIKU="OpenRouter/FreeRouter"
LITELLM_MODEL_ALIAS_SONNET_1M="NVIDIA/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_OPUS_1M="OCZ/MNP/Nemotron-3-Ultra-FREE"
LITELLM_MODEL_ALIAS_OPUSPLAN="OCZ/MNP/Nemotron-3-Ultra-FREE"

# ═══════════════════════════════════════════════════════════════════════════════
# Provider — Base URLs (set keys in .env.proxy.secrets if needed)
# ═══════════════════════════════════════════════════════════════════════════════
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
