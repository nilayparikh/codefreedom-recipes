# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — Secrets for free-tier models
# ═══════════════════════════════════════════════════════════════════════════════
# No API keys are required — all models are free tier.
# If you want higher rate limits, set keys for individual providers.
# NEVER commit this file to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LiteLLM Proxy Master Key ───────────────────────────────────────────────
# Used to authenticate requests to the local proxy.
# This is the ANTHROPIC_AUTH_TOKEN value used in Claude Code profiles.
LITELLM_MASTER_KEY=sk-codefreedom-local

# ── Optional API keys (for higher rate limits) ─────────────────────────────
# Leave empty to use free tier without auth.
# OPENCODE_ZEN_API_KEY_MNP=
# NVIDIA_API_KEY=
# OPENROUTER_API_KEY=
