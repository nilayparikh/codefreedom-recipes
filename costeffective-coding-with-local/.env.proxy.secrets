# ── .env.proxy.secrets ────────────────────────────────────────────────────────
# Proxy secrets loaded by docker-compose.yaml via env_file.
# Fill in your API keys below.
#
# NEVER commit this file to git. It is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# Microsoft Foundry (Azure)
# MICROSOFT_FOUNDRY_API_BASE=https://<ws>.services.ai.azure.com/openai/v1
# MICROSOFT_FOUNDRY_API_KEY=

# OpenCode Zen
# OPENCODE_ZEN_API_KEY=

# OpenRouter
# OPENROUTER_API_KEY=
