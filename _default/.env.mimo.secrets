# MiMoCode secrets — loaded by `cf mimo` and `cf mc`
#
# PROXY_API_KEY — API key for the LiteLLM proxy
#   Injected into the generated mimocode.json so mimo can authenticate.
#
# GITHUB_PERSONAL_ACCESS_TOKEN — used when the sandbox needs GitHub access
PROXY_API_KEY=${LITELLM_MASTER_KEY}
GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_PERSONAL_ACCESS_TOKEN}
