# MiMoCode configuration — loaded by `cf mimo` and `cf mc`
# This file is managed by codefreedom recipes. Override values in .env.user.
#
# LITELLM_BASE_URL — URL of the running CodeFreedom proxy (default: http://localhost:4000)
#   Used by `cf mimo` to auto-generate mimocode.json with all proxy models.
#
# PROXY_API_KEY — API key for the LiteLLM proxy
#   Passed through to the generated mimocode.json provider config.
#
# MIMOCODE_DISABLE_AUTOUPDATE — prevents mimo from checking for updates
# MIMOCODE_DISABLE_MODELS_FETCH — skips fetching the remote model list
# MIMOCODE_DISABLE_CLAUDE_CODE — prevents inheriting Claude Code settings
# MIMOCODE_MIMO_ONLY — pure MiMoCode mode, no host provider env vars
LITELLM_BASE_URL=http://localhost:4000
PROXY_API_KEY=${LITELLM_MASTER_KEY}
MIMOCODE_DISABLE_AUTOUPDATE=1
MIMOCODE_DISABLE_MODELS_FETCH=1
MIMOCODE_DISABLE_CLAUDE_CODE=1
MIMOCODE_MIMO_ONLY=1
