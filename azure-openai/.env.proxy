# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for Azure AI Foundry
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe uses Azure AI Foundry (Azure OpenAI) as the sole provider.
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Instance identifier ───────────────────────────────────────────
SUFFIX_ID=0000

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — all pointing to Azure GPT-5.4 family
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/azure-foundry.yaml.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_BEST="Azure/GPT-5.4"
LITELLM_MODEL_ALIAS_FABLE="Azure/GPT-5.4"
LITELLM_MODEL_ALIAS_SONNET="Azure/GPT-5.4-Mini"
LITELLM_MODEL_ALIAS_OPUS="Azure/GPT-5.4"
LITELLM_MODEL_ALIAS_HAIKU="Azure/GPT-5.4-Nano"
LITELLM_MODEL_ALIAS_SONNET_1M="Azure/GPT-5.4-Mini"
LITELLM_MODEL_ALIAS_OPUS_1M="Azure/GPT-5.4"
LITELLM_MODEL_ALIAS_OPUSPLAN="Azure/GPT-5.4"

# ═══════════════════════════════════════════════════════════════════════════════
# Azure — Base URL
# ═══════════════════════════════════════════════════════════════════════════════
# Override MICROSOFT_FOUNDRY_API_BASE in .env.proxy.secrets with your endpoint.
MICROSOFT_FOUNDRY_API_BASE=https://ergox-ca-resource.services.ai.azure.com/openai/v1
