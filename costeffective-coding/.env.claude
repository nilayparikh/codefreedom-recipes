# ── .env.claude.example ─────────────────────────────────────────────────────
# Claude Code agent configuration for CodeFreedom.
# This file is tracked in git — update it whenever you add or rename a variable.
#
# Copy to ~/.codefreedom/.env.claude to activate:
#   codefreedom claude init
#
# Configure: https://nilayparikh.github.io/codefreedom/claude-code/local/
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# Anthropic API — Direct (native models, bypass proxy)
# ═══════════════════════════════════════════════════════════════════════════════
# Set these when using --native-models to connect directly to Anthropic.
# Leave empty to route through the CodeFreedom proxy (recommended).
#
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ═══════════════════════════════════════════════════════════════════════════════
# Claude Code — Runtime settings
# ═══════════════════════════════════════════════════════════════════════════════
CLAUDE_CODE_COLUMNS=80
CLAUDE_CODE_LINES=24
