# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — Secrets
# ═══════════════════════════════════════════════════════════════════════════════
# Loaded by docker-compose.yaml via env_file.
# Fill in your API keys below. Leave empty to skip that provider.
#
# ⚠️  RECOMMENDATION: Set secrets as machine environment variables with the
#     CF_CLI_ prefix instead of keeping them in files. Export in your shell
#     profile (~/.bashrc, ~/.zshrc). The CLI strips the CF_CLI_ prefix and
#     injects the real name automatically:
#
#       export CF_CLI_LITELLM_MASTER_KEY="sk-codefreedom-local"
#       export CF_CLI_MICROSOFT_FOUNDRY_API_KEY="sk-..."
#
# Alternatively, run the assisted setup script to configure all secrets:
#   Bash:  bash <CODEFREEDOM_HOME>/scripts/costeffective-coding/setup-secrets.sh
#   PS:    <CODEFREEDOM_HOME>\scripts\costeffective-coding\setup-secrets.ps1
#
# NEVER commit this file to git. It is already in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LiteLLM Proxy Auth ─────────────────────────────────────────────────────
# Master key for the LiteLLM proxy — clients (Claude Code, MiMoCode) use
# this to authenticate with the proxy.
# Set on machine: export CF_CLI_LITELLM_MASTER_KEY="sk-codefreedom-local"
# Default: sk-codefreedom-local (run: openssl rand -hex 32 for custom)
# LITELLM_MASTER_KEY=

# ── Microsoft Foundry (Azure) ──────────────────────────────────────────────
# Azure AI Foundry endpoint — region-specific workspace URL.
# Set on machine: export CF_CLI_MICROSOFT_FOUNDRY_API_BASE="https://<ws>.services.ai.azure.com/openai/v1"
# MICROSOFT_FOUNDRY_API_BASE=

# Azure AI Foundry API key — set in Azure AI Foundry portal.
# Set on machine: export CF_CLI_MICROSOFT_FOUNDRY_API_KEY="sk-..."
# MICROSOFT_FOUNDRY_API_KEY=

# ── OpenCode Zen (free tier + GO subscription) ─────────────────────────────
# OpenCode API key — get from https://opencode.ai dashboard.
# Covers both Zen (free) and GO (subscription) models.
# Set on machine: export CF_CLI_OPENCODE_ZEN_API_KEY="sk-..."
# OPENCODE_ZEN_API_KEY=

# ── OpenRouter ─────────────────────────────────────────────────────────────
# OpenRouter API key — get from https://openrouter.ai/keys
# Set on machine: export CF_CLI_OPENROUTER_API_KEY="sk-..."
# OPENROUTER_API_KEY=

# ── GitHub (sandbox mode) ──────────────────────────────────────────────────
# GitHub personal access token — used in sandbox mode for git push/pull.
# Set on machine: export CF_CLI_GITHUB_PERSONAL_ACCESS_TOKEN="ghp_..."
# Get one at: https://github.com/settings/tokens
# GITHUB_PERSONAL_ACCESS_TOKEN=

# GitHub token (alias) — usually the same value as GITHUB_PERSONAL_ACCESS_TOKEN.
# Set on machine: export CF_CLI_GH_TOKEN="ghp_..."
# GH_TOKEN=
