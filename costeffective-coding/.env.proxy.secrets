# ── .env.proxy.secrets.example ─────────────────────────────────────────────────
# Template for proxy secrets. Copy to .env.proxy.secrets and fill in your values.
#
#   cp .env.proxy.secrets.example .env.proxy.secrets
#
# NEVER commit .env.proxy.secrets to git. It is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy Master Key
# ═══════════════════════════════════════════════════════════════════════════════
# Used to authenticate requests to the LiteLLM proxy.
# This is the value you use as ANTHROPIC_AUTH_TOKEN in Claude Code profiles.
# Generate a strong random key — this is the default, CHANGE IT for production.
# LITELLM_MASTER_KEY=sk-change-me


# ═══════════════════════════════════════════════════════════════════════════════
# Database Password (PostgreSQL only — not needed for SQLite)
# ═══════════════════════════════════════════════════════════════════════════════
# LITELLM_DB_PASSWORD=change-me


# ═══════════════════════════════════════════════════════════════════════════════
# Cloud Provider API Keys
# ═══════════════════════════════════════════════════════════════════════════════
# Set the key for each provider you want to enable.
# Leave empty (or delete the line) to disable that provider.

# DeepSeek — https://api.deepseek.com
# DEEPSEEK_API_KEY=

# Microsoft Foundry (Azure AI) — https://tuts.services.ai.azure.com/openai/v1
# MICROSOFT_FOUNDRY_API_KEY=

# NVIDIA AI Endpoints — https://integrate.api.nvidia.com/v1
# NVIDIA_API_KEY=

# OpenCode Zen — https://opencode.ai/zen/v1 (free tier available)
# OPENCODE_ZEN_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# OpenAI-Compatible Endpoint (bring your own model)
# ═══════════════════════════════════════════════════════════════════════════════
# OPENAI_COMPAT_API_KEY=sk-your-key


# ═══════════════════════════════════════════════════════════════════════════════
# Anthropic-Compatible Endpoint (bring your own model)
# ═══════════════════════════════════════════════════════════════════════════════
# ANTHROPIC_COMPAT_API_KEY=
