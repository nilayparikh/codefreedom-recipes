# ── .env.proxy.example ────────────────────────────────────────────────────────
# LiteLLM proxy configuration for CodeFreedom.
# This file is tracked in git — update it whenever you add or rename a variable.
#
# Copy to ~/.codefreedom/.env.proxy to activate:
#   codefreedom proxy init
#
# Configure: https://nilayparikh.github.io/codefreedom/proxy/
# ──────────────────────────────────────────────────────────────────────────────


# LiteLLM Proxy — core proxy settings

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO
LITELLM_NO_DOCS="True"
LITELLM_NO_REDOC="True"
LITELLM_JSON_LOGS=true
LITELLM_REQUIRE_AUTH_METRICS=false

# ── Privacy / Logging ────────────────────────────────────────────────────────
LITELLM_DROP_PARAMS=true
LITELLM_REDACT_USER_API_KEY=true
LITELLM_TURN_OFF_MSG_LOGGING=false
LITELLM_STREAM_USAGE=true

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5
LITELLM_RETRY_AFTER=0
LITELLM_TIMEOUT_ERROR_RETRIES=5
LITELLM_RATE_LIMIT_ERROR_RETRIES=5
LITELLM_INTERNAL_ERROR_RETRIES=5


# Model Aliases — each corresponds to a Claude Code alias.
# Override via env var to route an alias to a different model group.
# See docs/proxy/model-aliases.md for the full reference.
LITELLM_MODEL_ALIAS_BEST="OpenCode/Qwen3.7-Max"
LITELLM_MODEL_ALIAS_FABLE="OpenCode/Qwen3.7-Max"
LITELLM_MODEL_ALIAS_SONNET="OpenCode/DeepSeek-V4-Flash"
LITELLM_MODEL_ALIAS_OPUS="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_HAIKU="OpenCode/DeepSeek-V4-Flash"
LITELLM_MODEL_ALIAS_SONNET_1M="OpenCode/DeepSeek-V4-Flash"
LITELLM_MODEL_ALIAS_OPUS_1M="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_OPUSPLAN="DeepSeek/DeepSeek-V4-Pro"
LITELLM_MODEL_ALIAS_CUSTOM="OpenCode/DeepSeek-V4-Flash"


# Cloud Provider — Base URLs
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_ANTHROPIC_BASE_URL=https://opencode.ai/zen/go
COMMAND_CODE_BASE_URL=https://api.commandcode.ai/provider/v1/


# Web Search Bridge (SearXNG-shaped → Camoufox MCP)
# Replaces Claude Code's native WebSearch with calls to the local Camoufox
# MCP web_search tool via a SearXNG-shaped HTTP bridge. See
# docs/proxy/websearch-interception.md and docs/faq/web-search.md.

# Container name
WEB_BRIDGE_CONTAINER_NAME=codefreedom-web-bridge

# Fully-qualified image tag. The proxy CLI uses this for `docker build -t`
# and docker-compose references it via `image: ${WEB_BRIDGE_IMAGE}`. Default
# is the published Docker Hub reference, so the local build is directly
# pushable with `docker push ${WEB_BRIDGE_IMAGE}` — no retag required.
WEB_BRIDGE_IMAGE=docker.io/nilayparikh/codefreedom:web-bridge

# Address of the Camoufox MCP web_search endpoint. Default points at the
# host's port 8420 — `codefreedom tools web` publishes the MCP there.
MCP_WEB_URL=http://host.docker.internal:8420/mcp

# Per-call cooldown in seconds. The bridge returns HTTP 429 if a second
# /search arrives within this window. 2.0 is a good default.
WEB_BRIDGE_COOLDOWN_SECONDS=2.0

# Per-call MCP HTTP timeout. Should be larger than the MCP's own cooldown
# (default 10s) plus browser-render time.
MCP_TIMEOUT_SECONDS=60
