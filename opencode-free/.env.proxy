# ═══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy — core settings for OpenCode Zen free-tier
# ═══════════════════════════════════════════════════════════════════════════════
# This recipe uses OpenCode Zen as the sole provider. The embedded
# PostgreSQL inside the LiteLLM image is used automatically — no
# external database setup needed.
#
# Config: https://nilayparikh.github.io/codefreedom/proxy/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Container ────────────────────────────────────────────────────────────────
LITELLM_IMAGE=docker.io/nilayparikh/codefreedom:litellm-latest
LITELLM_CONTAINER_NAME=litellm-codefreedom
LITELLM_DATA_VOLUME=codefreedom-litellm-data

# ── Instance identifier ───────────────────────────────────────────
SUFFIX_ID=0000

# ── Networking ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_BIND_HOST=0.0.0.0

# ── Observability ────────────────────────────────────────────────────────────
LITELLM_LOG_LEVEL=INFO

# ── Retry / Resilience ───────────────────────────────────────────────────────
LITELLM_NUM_RETRIES=5

# ═══════════════════════════════════════════════════════════════════════════════
# Model Aliases — all pointing to OpenCode Zen free-tier
# ═══════════════════════════════════════════════════════════════════════════════
# Each alias must match a model_name from proxy/config/providers/opencode.yaml.
# Override any alias in your .env.proxy.secrets file.

LITELLM_MODEL_ALIAS_BEST="OpenCode/MiMo-V2.5-FREE"
LITELLM_MODEL_ALIAS_FABLE="OpenCode/MiMo-V2.5-FREE"
LITELLM_MODEL_ALIAS_SONNET="OpenCode/DeepSeek-V4-Flash-FREE"
LITELLM_MODEL_ALIAS_OPUS="OpenCode/MiMo-V2.5-FREE"
LITELLM_MODEL_ALIAS_HAIKU="OpenCode/Nemotron-3-Ultra-FREE"
LITELLM_MODEL_ALIAS_SONNET_1M="OpenCode/DeepSeek-V4-Flash-FREE"
LITELLM_MODEL_ALIAS_OPUS_1M="OpenCode/MiMo-V2.5-FREE"
LITELLM_MODEL_ALIAS_OPUSPLAN="OpenCode/MiMo-V2.5-FREE"

# ═══════════════════════════════════════════════════════════════════════════════
# OpenCode Zen — Base URL
# ═══════════════════════════════════════════════════════════════════════════════
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1


# ═══════════════════════════════════════════════════════════════════════════════
# 5. OpenAI-Compatible Endpoint (bring your own model)
# ═══════════════════════════════════════════════════════════════════════════════
# OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPAT_MODEL=openai/your-model-name


# ═══════════════════════════════════════════════════════════════════════════════
# 6. Anthropic-Compatible Endpoint (bring your own model)
# ═══════════════════════════════════════════════════════════════════════════════
# ANTHROPIC_COMPAT_BASE_URL=http://localhost:8000
# ANTHROPIC_COMPAT_MODEL=claude-sonnet-4-20250514


# ═══════════════════════════════════════════════════════════════════════════════
# 7. Local Backends (pre-configured, two ports)
# ═══════════════════════════════════════════════════════════════════════════════
# LOCAL_M_BASE_URL=http://host.docker.internal:8000/v1
# LOCAL_S_BASE_URL=http://host.docker.internal:8001/v1


# ═══════════════════════════════════════════════════════════════════════════════
# 8. Web Search Bridge (SearXNG-shaped → Camoufox MCP)
# ═══════════════════════════════════════════════════════════════════════════════
# Replaces Claude Code's native WebSearch with calls to the local Camoufox
# MCP web_search tool via a SearXNG-shaped HTTP bridge. See
# docs/proxy/websearch-interception.md and docs/faq/web-search.md.
#
# To enable:
#   1. Make sure `codefreedom tools web start` is running.
#   2. Uncomment the `websearch_interception` callback and the `search_tools`
#      block in proxy/config/config.yaml.
#   3. `codefreedom proxy restart` to pick up the changes.

# Container name
WEB_BRIDGE_CONTAINER_NAME=codefreedom-web-bridge

# Fully-qualified image tag. The proxy CLI uses this for `docker build -t`
# and docker-compose references it via `image: ${WEB_BRIDGE_IMAGE}`. Default
# is the published Docker Hub reference, so the local build is directly
# pushable with `docker push ${WEB_BRIDGE_IMAGE}` — no retag required.
WEB_BRIDGE_IMAGE=docker.io/nilayparikh/codefreedom:web-bridge

# Address of the Camoufox MCP web_search endpoint. Default points at the
# host's port 8420 — `codefreedom tools web` publishes the MCP there.
MCP_WEB_URL=http://host.docker.internal:8420/mcp

# Per-call cooldown in seconds. The bridge returns HTTP 429 if a second
# /search arrives within this window. 2.0 is a good default.
WEB_BRIDGE_COOLDOWN_SECONDS=2.0

# Per-call MCP HTTP timeout. Should be larger than the MCP's own cooldown
# (default 10s) plus browser-render time.
MCP_TIMEOUT_SECONDS=60
