# ═══════════════════════════════════════════════════════════════════════════════
# Claude Code — Runtime settings
# ═══════════════════════════════════════════════════════════════════════════════
# Claude Code uses the proxy for model routing via ANTHROPIC_BASE_URL
# and ANTHROPIC_AUTH_TOKEN, which are set in profiles/claude-code.json.
# No additional env vars are needed for this recipe.
# ═══════════════════════════════════════════════════════════════════════════════

CLAUDE_CODE_COLUMNS=80
CLAUDE_CODE_LINES=24
